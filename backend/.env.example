PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/messwala?retryWrites=true&w=majority

# JWT & Security
JWT_SECRET=<generate-a-strong-random-secret-minimum-32-chars>
JWT_EXPIRE=30d
FRONTEND_URL=https://your-frontend-domain.vercel.app
NODE_ENV=production

# Email (Gmail) - Used for notifications and password resets
# Setup: Enable 2FA on Gmail, then generate an App Password
# Reference: https://support.google.com/accounts/answer/185833
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password-16-chars

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Twilio WhatsApp Configuration (Optional)
# Setup instructions:
# 1. Create account: https://www.twilio.com/console
# 2. Get Account SID and Auth Token from console
# 3. Get or create a WhatsApp-enabled Twilio phone number
# 4. Add your test phone number to sandbox (for trial account)
# 5. WhatsApp templates require approval in production
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_PHONE_NUMBER=+14155238886
# Your test phone number (required during Twilio trial)
# Format: +91 for India, +1 for US, etc.
TWILIO_TEST_PHONE=+91xxxxxxxxxx

# Backups
BACKUP_ENABLED=true
