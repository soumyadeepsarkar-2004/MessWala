# MessWala Docker Environment Variables
# Copy this to .env and fill in production values before running docker-compose

# 🔒 Database Configuration (REQUIRED FOR PRODUCTION)
MONGO_ROOT_USER=messwala_admin
MONGO_ROOT_PASSWORD=your-strong-random-password-here
MONGODB_URI=mongodb://messwala_admin:your-strong-random-password-here@mongodb:27017/messwala?authSource=admin

# 🔒 Backend Configuration (REQUIRED)
NODE_ENV=production
PORT=5000

# 🔑 JWT Configuration (REQUIRED - Generate a cryptographically secure 32+ char string)
# Linux/Mac: openssl rand -base64 32
# Windows: Use an online generator or [System.Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes((1..32|ForEach-Object{[char](Get-Random -Min 33 -Max 127))} -join ''))
JWT_SECRET=your-cryptographically-secure-random-string-minimum-32-characters

# 🌐 Frontend URL (REQUIRED - Your production frontend domain)
FRONTEND_URL=https://your-frontend-app.vercel.app

# 📱 Google OAuth Configuration (REQUIRED for student logins)
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# 🎯 Frontend Configuration (REQUIRED - Your production backend domain)
VITE_API_BASE_URL=https://your-backend-api.onrender.com

# ========== OPTIONAL CONFIGURATIONS ==========

# 📧 Email Configuration (Optional - for password reset functionality)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-specific-password

# 🔄 Backup Configuration (Optional)
# BACKUP_ENABLED=true
# BACKUP_INTERVAL=86400
