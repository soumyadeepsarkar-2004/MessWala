{
  "name": "messwala-backend",
  "version": "1.0.1",
  "description": "MessWala - Hostel Mess Management System Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "seed": "node src/seed/seed.js",
    "validate": "node validate-production-env.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "health:check": "curl -s http://localhost:5000/api/health | jq .",
    "health:summary": "curl -s http://localhost:5000/api/admin/health-summary | jq .",
    "cache:stats": "curl -s http://localhost:5000/api/admin/cache/stats | jq .",
    "cache:clear": "curl -X POST -s http://localhost:5000/api/admin/cache/clear | jq .",
    "jobs:status": "curl -s http://localhost:5000/api/admin/jobs/status | jq .",
    "jobs:clear-failed": "curl -X POST -s http://localhost:5000/api/admin/jobs/clear-failed | jq .",
    "docs:generate": "node -e \"const { APIDocGenerator } = require('./src/utils/apiDocGenerator'); const gen = new APIDocGenerator(); console.log(JSON.stringify(gen.generateOpenAPI(), null, 2))\"",
    "docs:html": "node -e \"const { APIDocGenerator } = require('./src/utils/apiDocGenerator'); const gen = new APIDocGenerator(); require('fs').writeFileSync('./api-docs.html', gen.generateHTML())\" && echo 'API docs generated in api-docs.html'",
    "backup:create": "curl -X POST -s http://localhost:5000/api/admin/backup | jq .",
    "backup:list": "curl -s http://localhost:5000/api/admin/backups | jq ."
  },
  "keywords": [
    "hostel",
    "mess",
    "management",
    "analytics"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.2",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.1.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0",
    "nodemailer": "^8.0.1",
    "twilio": "^4.23.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3"
  }
}
