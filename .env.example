# ===========================
# MessWala Environment Configuration
# ===========================
# Copy this file to .env and fill in the required values

# ===========================
# Core Application Settings
# ===========================
NODE_ENV=development
PORT=5000
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-required-for-production
JWT_EXPIRE=30d

# ===========================
# Frontend Configuration
# ===========================
FRONTEND_URL=http://localhost:5173
# For production, use your frontend domain: https://yourdomain.com

# ===========================
# Database Configuration
# ===========================
MONGO_URI=mongodb+srv://username:password@cluster0.mongodb.net/messwala?retryWrites=true&w=majority
# Format: mongodb+srv://user:pass@host/database?retryWrites=true&w=majority

# ===========================
# Email Notifications (Gmail)
# ===========================
# Generate app password at: https://myaccount.google.com/apppasswords
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-16-character-app-password

# ===========================
# WhatsApp Notifications (Twilio)
# ===========================
# Sign up at: https://www.twilio.com
# Get credentials from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_PHONE_NUMBER=+14155238886
# For sandbox development, this is the Twilio sandbox number
# For production, purchase a verified WhatsApp number

# Test phone number for development (your personal WhatsApp number)
TWILIO_TEST_PHONE=+91xxxxxxxxxx

# ===========================
# Backup Configuration
# ===========================
BACKUP_ENABLED=true
# Enable/disable automated database backups

# ===========================
# Caching (Optional)
# ===========================
# Redis is optional. Leave empty to disable caching
REDIS_URL=redis://localhost:6379

# ===========================
# Logging
# ===========================
LOG_LEVEL=info
# Options: error, warn, info, debug

# ===========================
# Platform-Specific Settings
# ===========================
# For Render deployment
RENDER_EXTERNAL_URL=

# For Vercel deployment (auto-set by Vercel)
VERCEL=

# ===========================
# Google Integration (Optional)
# ===========================
# Get from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================
# reCAPTCHA (Optional)
# ===========================
# Get from: https://www.google.com/recaptcha/admin
VITE_RECAPTCHA_SITE_KEY=

# ===========================
# Production Deployment Notes
# ===========================
# 1. Ensure JWT_SECRET is at least 64 characters
# 2. Use HTTPS URL for FRONTEND_URL in production
# 3. Configure all notification services for redundancy
# 4. Set LOG_LEVEL=warn in production for performance
# 5. Enable BACKUP_ENABLED=true for data safety
# 6. Review CORS settings in server.js before production
